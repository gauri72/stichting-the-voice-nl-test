# Set to "true" to show the maintenance page instead of the full site.
# VITE_MAINTENANCE_MODE=true

# ISO 8601 UTC datetime for the maintenance countdown target.
# Defaults to 2026-05-24T10:12:00.000Z (24 May 2026, 12:12 PM CEST).
# VITE_SITE_LAUNCH_DATETIME=2026-05-24T10:12:00.000Z

# WhatsApp chat button (country code + number, digits only; +31 6 19032104)
VITE_WHATSAPP_E164=31619032104

# WhatsApp community group invite link (footer + hero)
# VITE_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/your-group-invite

# Stripe publishable key (live mode: pk_live_...).
# Same Stripe account as server STRIPE_SECRET_KEY — https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# Optional: override the API base URL. Leave empty to use the Vite proxy at /api.
# VITE_API_BASE_URL=http://localhost:5000

# Google Sign-In (OAuth 2.0 Web client ID from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
