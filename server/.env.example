PORT=5000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/voice_nl
NODE_ENV=development

# --- Stripe ---
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# After running `stripe listen --forward-to localhost:5000/api/payments/webhook`
# Stripe CLI prints a "whsec_..." signing secret. Paste it here.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# 3-letter ISO currency code used for sponsorship payments
PAYMENT_CURRENCY=eur

# --- Email (Nodemailer SMTP) ---
# Works with Gmail (host=smtp.gmail.com, port=465, secure=true, EMAIL_PASS = App Password),
# SendGrid (host=smtp.sendgrid.net, port=587, EMAIL_USER=apikey, EMAIL_PASS=<api_key>),
# or any other SMTP provider.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
# Friendly From line shown to recipients
EMAIL_FROM="Stichting The V.O.I.C.E. NL <your_email@gmail.com>"
# Optional: where internal sponsorship notifications are sent
ORG_NOTIFY_EMAIL=info@thevoice.nl

# --- Sponsorship receipt + email branding ---
# Public-facing foundation contact email used inside emails/receipts.
CONTACT_EMAIL=info@thevoicenl.org
# One-line tagline shown under the wordmark on the PDF receipt.
ORG_TAGLINE=The voice of international cultural exchange in the Netherlands
# pCloud (or other) link sponsors use to upload their assets after payment.
SPONSOR_UPLOAD_URL=https://e.pcloud.com/#/puplink?code=a0d7Z7oHyALJyo1QSVj7EPvLx5y5ySo37
