PORT=5000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/voice_nl
NODE_ENV=development

# --- Auth (JWT) ---
# Required in production. Use a long random string (e.g. openssl rand -base64 48).
JWT_SECRET=change_me_to_a_long_random_secret

# --- Google Sign-In (same Web client ID as client VITE_GOOGLE_CLIENT_ID) ---
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# --- Ticket Tailor (dashboard tickets, membership, donations) ---
# API key from Box office settings → API. Used server-side only.
# IMPORTANT: When creating the key, disable "hide personal data" so buyer emails are not masked (****).
TICKET_TAILOR_API_KEY=
# TICKET_TAILOR_API_BASE=https://api.tickettailor.com
# Product IDs for Donate / sponsorship products (comma-separated)
# TICKET_TAILOR_DONATION_PRODUCT_IDS=pr_23684
# TICKET_TAILOR_SPONSORSHIP_PRODUCT_IDS=

# --- Stripe (live account) ---
# Live keys: https://dashboard.stripe.com/apikeys (toggle Live mode, top-right)
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
# Live webhook signing secret: Developers → Webhooks → your endpoint → Signing secret
# Endpoint URL: https://<your-api-host>/api/payments/webhook
# Events: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_your_live_webhook_secret_here
# 3-letter ISO currency code used for sponsorship payments
PAYMENT_CURRENCY=eur

# --- Email (Nodemailer SMTP) ---
# SiteGround (recommended if your domain email is hosted there):
#   Site Tools → Email → Accounts → Mail Configuration → Manual settings
#   EMAIL_HOST is usually mail.yourdomain.com, port 465, secure=true
# Also works with Gmail, SendGrid, Mailgun, or any SMTP provider.
EMAIL_HOST=mail.stichtingthevoice.nl
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=info@stichtingthevoice.nl
EMAIL_PASS=your_mailbox_password
# Friendly From line — use the same mailbox as EMAIL_USER for SiteGround
EMAIL_FROM=Stichting The V.O.I.C.E. NL <info@stichtingthevoice.nl>
# Optional: public contact / receipt footer (donation & sponsorship emails, PDF footers)
CONTACT_EMAIL=info@stichtingthevoice.nl
# Optional: where internal notifications are sent
ORG_NOTIFY_EMAIL=info@stichtingthevoice.nl

# --- Sponsorship receipt + email branding ---
# Optional: extra line below donation thank-you email (plain text; shown centered under the card).
EMAIL_FOOTER_OPTIONAL=

# One-line tagline shown under the wordmark on the PDF receipt.
ORG_TAGLINE=The voice of international cultural exchange in the Netherlands
# pCloud (or other) link sponsors use to upload their assets after payment.
SPONSOR_UPLOAD_URL=https://e.pcloud.com/#/puplink?code=a0d7Z7oHyALJyo1QSVj7EPvLx5y5ySo37
